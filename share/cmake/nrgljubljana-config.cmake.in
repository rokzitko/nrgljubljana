# This file allows other CMake Projects to find us
# We provide general project information
# and reestablish the exported CMake Targets

@PACKAGE_INIT@

if(POLICY CMP0144) # find_package uses upper-case <PACKAGENAME>_ROOT variables
  cmake_policy(SET CMP0144 OLD)
endif()
if(POLICY CMP0167) # FindBoost module availability
  cmake_policy(SET CMP0167 OLD)
endif()

# Multiple inclusion guard
if(NOT NRGLJUBLJANA_FOUND)
set(NRGLJUBLJANA_FOUND True)

# version
set(NRGLJUBLJANA_VERSION @PROJECT_VERSION@)
set(NRGLJUBLJANA_GIT_HASH @PROJECT_GIT_HASH@)
set(NRGLJUBLJANA_ENABLE_APP_OPENMP @NRGLJUBLJANA_ENABLE_APP_OPENMP@)
set(NRGLJUBLJANA_NEEDS_OPENMP_RUNTIME @NRGLJUBLJANA_NEEDS_OPENMP_RUNTIME@)
set(NRGLJUBLJANA_MKL_THREADING_LAYER @NRGLJUBLJANA_EFFECTIVE_MKL_THREADING_LAYER@)

# Root of the installation
set(NRGLJUBLJANA_ROOT "${PACKAGE_PREFIX_DIR}")

include(CMakeFindDependencyMacro)
set(Boost_NO_WARN_NEW_VERSIONS 1)
set(Boost_NO_BOOST_CMAKE ON)
set(Boost_USE_STATIC_LIBS OFF)
find_dependency(Boost 1.53 REQUIRED COMPONENTS serialization mpi)
find_dependency(MPI REQUIRED COMPONENTS CXX)
find_dependency(LAPACK REQUIRED)
if(NRGLJUBLJANA_NEEDS_OPENMP_RUNTIME)
  find_dependency(OpenMP REQUIRED COMPONENTS CXX)
endif()

# Include the exported targets of this project
include("${CMAKE_CURRENT_LIST_DIR}/nrgljubljana-targets.cmake")

message(STATUS "Found nrgljubljana-config.cmake with version @PROJECT_VERSION@, hash = @PROJECT_GIT_HASH@")

# Was the Project built with Documentation?
set(NRGLJUBLJANA_WITH_DOCUMENTATION @Build_Documentation@)

endif()
