#%Module1.0
#
# To be installed as ${MODULEPATH}/nrgljubljana/@PROJECT_VERSION@

set     name        nrgljubljana
set     version     @PROJECT_VERSION@
set     root        @CMAKE_INSTALL_PREFIX@
set     git_hash    @PROJECT_GIT_HASH@

set     url         "https://github.com/rokzitko/nrgljubljana"
set     description "Numerical renormalization group framework for quantum impurity problems."

module-whatis   "$description"

proc ModulesHelp { } {
    global description url version git_hash
    puts stderr "Description: $description"
    puts stderr "URL:         $url"
    puts stderr "Version:     $version"
    puts stderr "Git hash:    $git_hash"
}

# Only one version of nrgljubljana can be loaded at a time
conflict $name

setenv          NRGLJUBLJANA_ROOT      $root
setenv          NRGLJUBLJANA_VERSION   $version
setenv          NRGLJUBLJANA_GIT_HASH  $git_hash

prepend-path    PATH                $root/@CMAKE_INSTALL_BINDIR@
prepend-path    PATH                $root/@NRGLJUBLJANA_INSTALL_NRGINIT_DIR@
prepend-path    CPLUS_INCLUDE_PATH  $root/@CMAKE_INSTALL_INCLUDEDIR@
prepend-path    LIBRARY_PATH        $root/@CMAKE_INSTALL_LIBDIR@
prepend-path    LD_LIBRARY_PATH     $root/@CMAKE_INSTALL_LIBDIR@
prepend-path    CMAKE_PREFIX_PATH   $root/@CMAKE_INSTALL_LIBDIR@/cmake/nrgljubljana
